NODE_ENV=development
GATEWAY_PORT=8080

# PostgreSQL
DATABASE_URL=postgresql://monolith_user:monolith_pass@localhost:5432/monolith_db

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production-must-be-32-chars
JWT_EXPIRES_IN=15m
REFRESH_SECRET=super-secret-refresh-key-change-in-production-must-be-32!
REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=debug
LOG_QUERIES=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*
